#!/usr/bin/env python3
"""
ctx-shrink v2 — Smart codebase analyzer for AI coding agents

Scans a project, maps architecture/endpoints/models/dependencies,
and outputs a smart context map (not a code dump).
Also checks .gitignore safety to prevent credential leaks like Claude Code's.
"""

import os, sys, json, re, argparse, fnmatch, subprocess
from pathlib import Path
from collections import defaultdict
from datetime import datetime

